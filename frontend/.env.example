# ── Auth ──────────────────────────────────────────────────────────────────────

# Secret used to sign NextAuth JWTs and session cookies.
# Must be at least 32 characters. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Canonical URL of this Next.js app — used by NextAuth for callbacks.
# In production set to your public domain, e.g. https://pos.example.com
NEXTAUTH_URL=

# ── Django backend ────────────────────────────────────────────────────────────

# Base URL of the Django REST API (no trailing slash).
# Local dev: http://localhost:8000
DJANGO_API=

# Shared secret used by the BFF to authenticate server-to-server calls
# to the Django backend. Must be at least 16 characters.
DJANGO_API_SECRET=

# ── Public runtime config ─────────────────────────────────────────────────────

# Which environment this terminal is running in.
# Controls feature flags and logging verbosity.
# Allowed values: development | staging | production
NEXT_PUBLIC_TERMINAL_ENV=

# Enable chaos-mode for manual resilience testing (simulates network failures).
# Set to "true" only in development or staging.
# Allowed values: true | false
NEXT_PUBLIC_CHAOS_MODE=

# Disable Sentry error reporting (useful in local dev to avoid noise).
# Allowed values: true | false
NEXT_PUBLIC_SENTRY_DISABLED=

# ── Optional third-party services ────────────────────────────────────────────

# PostHog project API key for product analytics.
# Leave empty to disable analytics entirely.
NEXT_PUBLIC_POSTHOG_KEY=

# Sentry DSN for error tracking.
# Leave empty (or set NEXT_PUBLIC_SENTRY_DISABLED=true) to disable Sentry.
NEXT_PUBLIC_SENTRY_DSN=
